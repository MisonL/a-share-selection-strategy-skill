{
  "schema_version": 3,
  "claim_boundary": "script_entrypoint_registry_only_not_runtime_dispatch_or_cli_contract_replacement",
  "categories": {
    "stable_cli": "User-facing local CLI entrypoints that may be copied from docs.",
    "fetch_cli": "Network or external-provider fetch entrypoints that must persist local files and metadata before scoring.",
    "gate_backtest_cli": "Audit, prediction, allocation, backtest, walk-forward, probe, or recovery entrypoints; outputs are gates or diagnostics, not investment proof.",
    "internal_helper": "Implementation helper modules. Direct execution, when present, is fail-fast only and not a user CLI contract."
  },
  "axes": {
    "visibility": {
      "public": "User-facing script entry that may be referenced by docs and copied into commands.",
      "internal": "Implementation detail; not a user CLI and not eligible for SKILL.md direct routing."
    },
    "kind": {
      "cli": "Executable command-line entrypoint with a user-facing contract.",
      "helper": "Importable implementation helper; direct execution is fail-fast only when present."
    },
    "stability": {
      "stable": "Stable local CLI entrypoint.",
      "stable_external": "Stable external-provider fetch CLI; network/provider behavior remains outside local proof.",
      "stable_gate": "Stable gate/backtest/probe CLI; output is diagnostic or audit evidence, not investment proof.",
      "internal": "Internal implementation surface with no user CLI compatibility promise."
    },
    "domain": {
      "selection_core": "Core local validation, scoring, symbols, data, metrics, and disclosure logic.",
      "fetch": "External or provider-specific data fetch logic.",
      "gate_backtest": "Allocation, prediction, backtest, walk-forward, probe, recovery, and artifact gates.",
      "report_html": "HTML report rendering and presentation helpers only.",
      "runner": "Today-runner orchestration helpers.",
      "walk_forward": "Walk-forward artifact and command helpers.",
      "compatibility_wrapper": "Root-level compatibility wrapper around internal lib implementation.",
      "internal_support": "Internal support helper that is not a public route."
    },
    "default_entry": {
      "true": "Core task-topology CLI that an Agent may select without first resolving a path-specific gate or provider.",
      "false": "Path-specific public CLI or internal helper; select only after the task route or artifact gate requires it."
    }
  },
